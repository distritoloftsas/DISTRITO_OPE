{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd distrito-backend && ./mvnw -DskipTests clean package"
  },
  "deploy": {
    "startCommand": "java -jar distrito-backend/target/distrito-backend-0.0.1-SNAPSHOT.jar",
    "healthcheckPath": "/actuator/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
